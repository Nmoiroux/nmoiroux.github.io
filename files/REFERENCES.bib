  author = {Ngou, Christelle M. and Bayib{\'e}ki, Albert N. and Abate, Luc and Makinde, Olesula S. and {Feufack-Donfack}, Lionel B. and {Sarah-Matio}, Elangwe M. and {Bouopda-Tuedom}, Aline G. and Taconet, Paul and Moiroux, Nicolas and {Awono-Amb{\'e}n{\'e}}, Parfait H. and Talman, Arthur and Ayong, Lawrence S. and Berry, Antoine and Nsango, Sandrine E. and Morlais, Isabelle},
