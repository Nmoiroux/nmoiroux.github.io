  title = {Impact of Sunlight Exposure on the Residual Efficacy of Biolarvicides {{Bacillus}} Thuringiensis Israelensis and {{Bacillus}} Sphaericus against the Main Malaria Vector, {{Anopheles}} Gambiae},
  author = {Zogo, Barnabas and Tchiekoi, Bertin N'Cho and Koffi, Alphonsine A. and Dahounto, Amal and Ahoua Alou, Ludovic P. and Dabir{\'e}, Roch K. and {Baba-Moussa}, Lamine and Moiroux, Nicolas and Pennetier, C{\'e}dric},
  year = 2019,
  month = feb,
