  title = {Small-Scale Field Testing of Alpha-Cypermethrin Water-Dispersible Granules in Comparison with the Recommended Wettable Powder Formulation for Indoor Residual Spraying against Malaria Vectors in {{Benin}}},
  author = {Moiroux, Nicolas and Dj{\`e}nontin, Armel and Zogo, Barnabas and Bouraima, Aziz and Sidick, Ibrahim and Pigeon, Olivier and Pennetier, C{\'e}dric},
