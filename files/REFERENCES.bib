  volume = {18},
  number = {1},
  pages = {55},
  issn = {1475-2875},
  doi = {10.1186/s12936-019-2687-0},
  abstract = {Biotic and abiotic factors have been reported to affect the larvicidal efficacy of Bacillus thuringiensis israelensis (Bti) and Bacillus sphaericus (Bs), although the extent to which they are affected has been poorly documented. This paper studies the effect of sunlight exposure on the efficacy of a new larvicide formulation based on both Bti and Bs, herein after referred to as BTBSWAX, applied against two different larval stages.},
  file = {/home/nm/Zotero/storage/P25PIB9E/Zogo et al. - 2019 - Impact of sunlight exposure on the residual effica.pdf;/home/nm/Zotero/storage/DTKF7D9V/s12936-019-2687-0.html}
}
