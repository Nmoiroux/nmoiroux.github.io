@misc{taconetLandUseLand2023a,
  title = {Land Use Land Cover Very High Resolution Map (1.5-m) for the Area of {{Korhogo}}, {{C\^ote}} d'{{Ivoire}}, 2018},
  author = {Taconet, Paul and Koffi Amanan, Alphonsine and Moiroux, Nicolas},
  year = 2023,
