@article{clegbanEvaluationYahePanda2021,
  title = {Evaluation of {{Yahe}}\textregistered{} and {{Panda}}\textregistered{} 2.0 Long-Lasting Insecticidal Nets against Wild Pyrethroid-Resistant {{Anopheles}} Gambiae s.l. from {{C\^ote}} d'{{Ivoire}}: An Experimental Hut Trial},
  shorttitle = {Evaluation of {{Yahe}}\textregistered{} and {{Panda}}\textregistered{} 2.0 Long-Lasting Insecticidal Nets against Wild Pyrethroid-Resistant {{Anopheles}} Gambiae s.l. from {{C\^ote}} d'{{Ivoire}}},
  author = {Clegban, Cyntia-Muriel Y. and Camara, Soromane and Koffi, A. Alphonsine and Ahoua Alou, Ludovic P. and Kabran Kouame, Jean-Paul and Koffi, A. Fernand and Kouassi, Philippe K. and Moiroux, Nicolas and Pennetier, C{\'e}dric},
  year = 2021,
  month = jul,
  journal = {Parasites \& Vectors},
  volume = {14},
  number = {1},
  pages = {347},
  issn = {1756-3305},
  doi = {10.1186/s13071-021-04843-x},
  urldate = {2021-07-02},
  abstract = {Long-lasting insecticidal nets (LLINs) have played an important role in reducing the global malaria burden since 2000. They are a core prevention tool used widely by people at risk of malaria. The Vector Control Prequalification mechanism of the Word Health Organization (WHO-Vector Control PQ) established the testing and evaluation guidelines for LLINs before registration for public use. In the present study, two new brands of deltamethrin-impregnated nets (Yahe\textregistered{} LN and Panda\textregistered{} Net 2.0) were evaluated in an experimental hut against wild pyrethroid-resistant Anopheles gambiae s.l. in M'B\'e nearby Bouak\'e, central C\^ote d'Ivoire.},
  keywords = {Anopheles gambiae s.l.,Cote d'Ivoire,Deltamethrin nets,Pyrethroid resistance},
  file = {/home/nm/Zotero/storage/RSPY6SML/Clegban et al. - 2021 - Evaluation of Yahe® and Panda® 2.0 long-lasting in.pdf;/home/nm/Zotero/storage/FVXZUEBG/s13071-021-04843-x.html}
}

