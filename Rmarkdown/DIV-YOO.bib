@article{comitepermanentinter-etatsdeluttecontrelasecheressedanslesahelLandscapesWestAfrica2016,
  title = {Landscapes of {{West Africa}} - {{A Window}} on a {{Changing World}}},
  author = {{Comit{\'e} Permanent Inter-{\'e}tats de Lutte contre la S{\'e}cheresse dans le Sahel}},
  year = 2016,
