  title = {Chapter 11 - {{Hierarchical Models}} for~{{Communities}}},
  booktitle = {Applied {{Hierarchical Modeling}} in {{Ecology}}},
  author = {K{\'e}ry, Marc and Royle, J. Andrew},
  editor = {K{\'e}ry, Marc and Royle, J. Andrew},
  year = 2016,
