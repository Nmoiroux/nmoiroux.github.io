  author = {Diallo, Diawo and Diagne, Cheikh T and Buenemann, Michaela and Ba, Yamar and Dia, Ibrahima and Faye, Oumar and Sall, Amadou A and Faye, Ousmane and Watts, Douglas M and Weaver, Scott C and Hanley, Kathryn A and Diallo, Mawlouth},
