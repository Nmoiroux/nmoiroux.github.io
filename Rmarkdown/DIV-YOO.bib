  doi = {10.1016/B978-0-12-801378-6.00011-4},
  urldate = {2022-10-24},
  abstract = {We present hierarchical models (HMs) for communities or metacommunities that are based on binary detection/nondetection---or ``presence/absence''---data, or based on counts; such models are sometimes called ``incidence-based'' and ``abundance-based,'' respectively. These HMs require data for multiple (or often all) species at a collection of sites covering some region of interest such as a park, state, or country. Species present at one site form a community, and those at multiple sites form a metacommunity. Our HMs permit characterization of the size and composition of both local communities and the metacommunity, thus enabling the study of alpha (local scale), beta (landscape scale), and gamma (macroscale) diversity. We progress through a series of models with increasing complexity that incorporate an increasing number of features that seem desirable in a (meta)community model, especially: (1) the ability to make inferences at multiple levels (metacommunity, local community, individual species) and (2) correction for measurement error. The community occupancy model, or DR model, of Dorazio and Royle (JASA, 2005) combines these features in a unique manner. We showcase the DR community occupancy model in this chapter. We show how to estimate species richness at metacommunity and local community levels, and how the response of species presence/absence to environmental covariates can be studied at both the community and the individual species level. We produce species richness maps and species accumulation curves that are corrected for imperfect species detection, and we study patterns of beta-diversity (turnover among sites) by comparing sites in terms of occurring species using a Jaccard index. In addition, we compare species in terms of the sites where they co-occur by applying a Jaccard index to the transposed presence/absence matrix. We also describe the Dorazio-Royle-Yamaura (DRY) community N-mixture model, which is the N-mixture version of the DR community occupancy model and has abundance rather than occurrence as its latent state. Both the DR community occupancy model and the DRY community abundance model are joint species distribution models (JSDMs) in the sense of describing the distribution of all species in a metacommunity in one single model. However, they assume that species occur independently conditional on modeled covariates, unlike similar models by Ovaskainen et~al. (2010), Clark et~al. (2014), Dorazio and Connor (2014) and Pollock et~al. (2014)Dorazio and Connor, 2014Pollock et~al., 2014. Independence may or may not be a sensible modeling assumption, and ought to be scrutinized for each application of the models. The independence assumption is more likely met for larger spatial and possibly also larger temporal scales, because of the greater possible number of spatial or temporal niches. In addition, independence seems more likely met for animal than plant metacommunities, because local competition for light and nutrients appears to be much fiercer for plants than it is among animal species, owing to a much larger dimensionality of the resources used by the latter.},
  isbn = {978-0-12-801378-6},
  langid = {english},
  keywords = {Community,Community -mixture model,Community occupancy model,Detection probability,Joint species distribution model,JSDM,Metacommunity,Multispecies abundance model,Multispecies occupancy model,Species accumulation,Species richness},
  file = {/home/nm/Zotero/storage/5IFFEHWM/B9780128013786000114.html}
}

@article{kraemerFutureSpreadArbovirus2019,
  title = {Past and Future Spread of the Arbovirus Vectors {{Aedes}} Aegypti and {{Aedes}} Albopictus},
  author = {Kraemer, Moritz U. G. and Reiner, Robert C. and Brady, Oliver J. and Messina, Jane P. and Gilbert, Marius and Pigott, David M. and Yi, Dingdong and Johnson, Kimberly and Earl, Lucas and Marczak, Laurie B. and Shirude, Shreya and Davis Weaver, Nicole and Bisanzio, Donal and Perkins, T. Alex and Lai, Shengjie and Lu, Xin and Jones, Peter and Coelho, Giovanini E. and Carvalho, Roberta G. and Van Bortel, Wim and Marsboom, Cedric and Hendrickx, Guy and Schaffner, Francis and Moore, Chester G. and Nax, Heinrich H. and Bengtsson, Linus and Wetter, Erik and Tatem, Andrew J. and Brownstein, John S. and Smith, David L. and Lambrechts, Louis and Cauchemez, Simon and Linard, Catherine and Faria, Nuno R. and Pybus, Oliver G. and Scott, Thomas W. and Liu, Qiyong and Yu, Hongjie and Wint, G. R. William and Hay, Simon I. and Golding, Nick},
  year = 2019,
  month = may,
  journal = {Nature Microbiology},
  volume = {4},
  number = {5},
  pages = {854--863},
  publisher = {Nature Publishing Group},
  issn = {2058-5276},
  doi = {10.1038/s41564-019-0376-y},
  urldate = {2023-03-11},
  abstract = {The global population at risk from mosquito-borne diseases---including dengue, yellow fever, chikungunya and Zika---is expanding in concert with changes in the distribution of two key vectors: Aedes aegypti and Aedes albopictus. The distribution of these species is largely driven by both human movement and the presence of suitable climate. Using statistical mapping techniques, we show that human movement patterns explain the spread of both species in Europe and the United States following their introduction. We find that the spread of Ae. aegypti is characterized by long distance importations, while Ae. albopictus has expanded more along the fringes of its distribution. We describe these processes and predict the future distributions of both species in response to accelerating urbanization, connectivity and climate change. Global surveillance and control efforts that aim to mitigate the spread of chikungunya, dengue, yellow fever and Zika viruses must consider the so far unabated spread of these mosquitos. Our maps and predictions offer an opportunity to strategically target surveillance and control programmes and thereby augment efforts to reduce arbovirus burden in human populations globally.},
  copyright = {2019 The Author(s)},
  langid = {english},
  keywords = {Infectious diseases,Microbiology},
  file = {/home/nm/Zotero/storage/M49NXAQI/Kraemer et al. - 2019 - Past and future spread of the arbovirus vectors Ae.pdf}
}

